<script>
  if (new URLSearchParams(window.location.search).get('open') === '0') {
    document.querySelectorAll('details[open]').forEach(d => d.open = false);
  }

  const button = document.getElementById('toggle-details');
  const details = () => document.querySelectorAll('details');

  function allOpen() {
    return [...details()].every(d => d.open);
  }

  button.addEventListener('click', () => {
    const open = !allOpen();
    details().forEach(d => d.open = open);
    button.textContent = open ? 'Collapse all exercises' : 'Expand all exercises';
  });
</script>

